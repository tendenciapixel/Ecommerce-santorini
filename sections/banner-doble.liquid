<div class="banner-grid-container section-{{ section.id }}">
  <div class="banner-grid-wrapper">
    {% for block in section.blocks %}
      <div class="banner-item">
        {%- if block.settings.image != blank -%}
          {{ block.settings.image | image_url: width: 1000 | image_tag: 
            loading: 'lazy', 
            sizes: '(min-width: 768px) 50vw, 100vw',
            widths: '400, 600, 800, 1000',
            alt: block.settings.button_label 
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
        <div class="banner-content">
          <a href="{{ block.settings.link }}" class="banner-button">
            {{ block.settings.button_label }}
          </a>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

<style>
  .banner-grid-container {
    padding: 20px 0;
    width: 100%;
  }
  .banner-grid-wrapper {
    display: grid;
    gap: 10px; /* Espacio entre imágenes */
    grid-template-columns: 1fr; /* Móvil: 1 columna */
  }
  
  /* Tablet */
  @media (min-width: 768px) {
    .banner-grid-wrapper {
      grid-template-columns: 1fr 1fr; /* 2 columnas */
    }
      .banner-item {
    aspect-ratio: 4 / 5;
  }
  }

  .banner-item {
    position: relative;
    overflow: hidden;
    {% comment %} height: auto; {% endcomment %}
    aspect-ratio: 16 / 9;
  }
  .banner-item img {
    {% comment %} width: 100%;
    height: 100%;
    object-fit: cover;
    display: block; {% endcomment %}
    width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
  }
  .banner-content {
    position: absolute;
    bottom: 20px;
    width: 100%;
    display: flex;
    justify-content: center;
  }
  .banner-button {
    background: #9C3F33
    border: 2px solid #ffffff;
    color: white;
    padding: 10px 40px;
    text-decoration: none;
    text-transform: uppercase;
    font-size: 14px;
    letter-spacing: 1px;
    transition: all 0.3s ease;
    backdrop-filter: blur(5px);
  }
  .banner-button:hover {
    background: white;
    color: #ffffff;
  }
</style>

{% schema %}
{
  "name": "Banner Doble Tendencia",
  "settings": [],
  "blocks": [
    {
      "type": "image",
      "name": "Imagen",
      "limit": 2,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Imagen"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Texto del Botón",
          "default": "Ver más"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Enlace"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Doble Tendencia",
      "blocks": [
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}